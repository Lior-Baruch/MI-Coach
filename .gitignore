# Environments / secrets — keys via env vars only, never committed
.env
.env.*
*.key
*.pem

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Thesis assets — adapter weights and raw thesis trees (which include training
# data/conversations) stay local; only assets/README.md is tracked
assets/*
!assets/README.md
!assets/therapist_system_prompt.txt
*.safetensors
*.gguf
*.bin

# Benchmark artifacts (raw runs; the summary table goes in README)
bench/results/

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store

# Logs
*.log
logs/

# Claude Code runtime state
.claude/scheduled_tasks.lock
!assets/thesis/
